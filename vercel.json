{
  "version": 2,
  "name": "nabatian-restaurant-demo",
  "builds": [
    {
      "src": "design2/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "design2/dist"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/design2/dist/$1"
    }
  ]
}
