---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Persisches Frühstück | Nabatian">
  <Header />
  
  <main class="pt-24">
    <Hero 
      title="FRÜHSTÜCK" 
      subtitle="Beginnen Sie Ihren Tag wie die Perser. Hier isst das Auge mit."
      backgroundImage="https://nabatian.de/wp-content/uploads/2022/01/Persian-Breakfast-III-comp-1024x1024.jpg"
    />

    <!-- Sobhaneye Irani Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="text-primary font-bold tracking-widest uppercase text-sm mb-4 block">Tradition</span>
            <h2 class="text-4xl font-serif text-neutral-900 mb-8 italic">Sobhaneye Irani</h2>
            <div class="prose prose-lg text-neutral-600 mb-10">
              <p>
                Genießen Sie den Start in den Tag mit einem traditionell persischem Frühstück. Unsere <strong>„SOBHANEYE IRANI“</strong> Auswahl für eine Person ist ein Fest für die Sinne:
              </p>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2 list-none p-0">
                <li class="flex items-center gap-2 font-medium text-neutral-800"><span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Cremiger Schafskäse</li>
                <li class="flex items-center gap-2 font-medium text-neutral-800"><span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Knackige Walnüsse</li>
                <li class="flex items-center gap-2 font-medium text-neutral-800"><span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Frische Kräuter</li>
                <li class="flex items-center gap-2 font-medium text-neutral-800"><span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Tomaten & Gurken</li>
                <li class="flex items-center gap-2 font-medium text-neutral-800"><span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Persisches Spiegelei</li>
                <li class="flex items-center gap-2 font-medium text-neutral-800"><span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Frische Datteln</li>
                <li class="flex items-center gap-2 font-medium text-neutral-800"><span class="w-1.5 h-1.5 bg-primary rounded-full"></span> Warmer Brotkorb</li>
              </ul>
              <p class="mt-8">
                Dazu servieren wir eine große Tasse persischen Schwarztee mit Kardamom, Minze und Zimt aus dem traditionellen Samowar – gereicht mit Nabat (Kandiszucker).
              </p>
            </div>

            <div class="bg-neutral-50 p-8 rounded-2xl border border-neutral-100 flex items-start gap-4">
              <div class="bg-primary/10 p-3 rounded-lg text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <div>
                <h4 class="font-bold text-neutral-900 mb-1">Frühstückszeiten</h4>
                <p class="text-neutral-600">Jeden Sonntag von 09:00 bis 12:00 Uhr.</p>
              </div>
            </div>
          </div>

          <div class="relative">
            <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl skew-y-1">
              <img 
                src="https://nabatian.de/wp-content/uploads/2022/01/Persian-Breakfast-III-comp-1024x1024.jpg" 
                alt="Persisches Frühstück Auswahl" 
                class="w-full h-full object-cover"
              />
            </div>
            <div class="absolute -bottom-8 -left-8 bg-white p-6 rounded-2xl shadow-xl max-w-[240px] border border-neutral-100 hidden md:block">
              <p class="text-sm italic text-neutral-600 leading-relaxed">
                "Das Frühstück ist die wichtigste Mahlzeit – im Orient zelebrieren wir sie."
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Vegan & Adasi Section -->
    <section class="py-24 bg-neutral-900 text-white overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="order-2 lg:order-1 relative">
            <img src="https://nabatian.de/wp-content/uploads/2022/01/vegan-breakfast_new.png" alt="Veganes Frühstück" class="rounded-3xl shadow-2xl relative z-10" />
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/20 rounded-full blur-3xl"></div>
          </div>

          <div class="order-1 lg:order-2">
            <h2 class="text-4xl font-serif mb-8 italic">Vegane Vielfalt & Adasi</h2>
            <div class="space-y-8 text-neutral-300 text-lg leading-relaxed">
              <p>
                Für unsere veganen Gäste haben wir die <strong>SOBHANEYE SONATI IRANI</strong> Kreation entwickelt: Cremiger Hummus, feine Datteln mit Rosenpulver, gefüllte Weinblätter und viele weitere orientalische Köstlichkeiten.
              </p>
              <div class="p-8 bg-white/5 rounded-2xl border border-white/10">
                <h4 class="text-xl font-serif text-primary mb-4">Adasi – Der Power-Eintopf</h4>
                <p class="text-base">
                  Ein proteinhaltiger Klassiker aus Linsen, Kartoffeln und Karotten, perfekt abgeschmeckt mit persischen Gewürzen und frischer Petersilie. Der ideale Start für einen energiegeladenen Tag.
                </p>
              </div>
            </div>
            <div class="mt-12">
               <a href="/kontakt" class="inline-block px-10 py-4 bg-primary text-white font-bold rounded-xl shadow-lg hover:bg-neutral-800 transition-all">Jetzt reservieren</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Menu PDF Download -->
    <section class="py-24 bg-white text-center">
        <div class="container mx-auto px-4">
            <h3 class="text-3xl font-serif mb-8">Details in unserer Karte</h3>
            <p class="text-neutral-600 mb-10 max-w-2xl mx-auto">
                Möchten Sie alle Details zu unserem Frühstücksangebot schwarz auf weiß? Laden Sie sich hier unsere aktuelle Frühstückskarte als PDF herunter.
            </p>
            <a 
              href="https://nabatian.de/wp-content/uploads/2021/12/RZ_FRUHSTUCKSKARTE_NABATIAN.pdf" 
              target="_blank" 
              class="inline-flex items-center gap-3 px-12 py-5 bg-neutral-900 text-white font-bold rounded-xl hover:bg-neutral-800 transition-all shadow-xl group"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-1 transition-transform"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Frühstückskarte (PDF)
            </a>
        </div>
    </section>
  </main>

  <Footer />
</Layout>
