---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

const title = "Restaurant | Nabatian - Persisches Restaurant Heilbronn";
const description = "Authentische persische Küche in Heilbronn. Genießen Sie traditionelle persische Spezialitäten in gemütlicher Atmosphäre am Sonnenbrunnen.";
---

<Layout title={title} description={description}>
  <Header />

  <Hero
    title="UNSER RESTAURANT"
    subtitle="Authentische persische Küche in gemütlicher Atmosphäre"
    backgroundImage="/images/hero-buffet.jpg"
    ctaText="JETZT RESERVIEREN"
    ctaLink="/kontakt"
  />

  <!-- Restaurant Info Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-['Maven_Pro'] font-medium mb-4">Willkommen im Nabatian</h2>
        <p class="text-lg font-['Maven_Pro'] max-w-3xl mx-auto leading-relaxed">
          Unser persisches Restaurant am Sonnenbrunnen in Heilbronn-Böckingen lädt Sie ein zu einer
          kulinarischen Reise durch die authentische persische Küche. Erleben Sie die Gastfreundschaft
          und Aromenvielfalt Persiens in gemütlicher Atmosphäre.
        </p>
      </div>

      <!-- Opening Hours Section -->
      <div class="bg-gray-50 rounded-lg p-8 mb-16">
        <h3 class="text-2xl font-['Maven_Pro'] font-medium mb-6 text-center">Öffnungszeiten</h3>
        <div class="max-w-md mx-auto space-y-3 font-['Maven_Pro']">
          <div class="flex justify-between border-b pb-2">
            <span>Montag & Dienstag:</span>
            <span class="text-[#711521] font-medium">Ruhetag</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span>Mittwoch & Donnerstag:</span>
            <span class="text-[#711521] font-medium">17:00 - 22:00 Uhr</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span>Freitag & Samstag:</span>
            <span class="text-[#711521] font-medium">17:00 - 23:00 Uhr</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span>Sonntag Frühstück:</span>
            <span class="text-[#711521] font-medium">09:00 - 12:00 Uhr</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <span>Sonntag Mittagessen:</span>
            <span class="text-[#711521] font-medium">12:00 - 14:00 Uhr</span>
          </div>
        </div>
        <p class="text-center font-['Maven_Pro'] text-sm mt-6 text-gray-600">
          Reservierungen empfohlen! ☎ +49 176 84512873
        </p>
      </div>

      <!-- Specialties Section -->
      <div class="mb-16">
        <h3 class="text-2xl font-['Maven_Pro'] font-medium mb-8 text-center">Unsere Spezialitäten</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Specialty 1 -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
            <h4 class="text-xl font-['Maven_Pro'] font-medium text-[#711521] mb-3">Persisches Buffet</h4>
            <p class="font-['Maven_Pro'] text-sm">
              Authentisches All-You-Can-Eat Buffet mit einer Vielzahl traditioneller persischer Gerichte.
              Perfekt zum Kennenlernen der persischen Küche.
            </p>
          </div>

          <!-- Specialty 2 -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
            <h4 class="text-xl font-['Maven_Pro'] font-medium text-[#711521] mb-3">Kebab-Variationen</h4>
            <p class="font-['Maven_Pro'] text-sm">
              Saftige Spieße vom Grill - Joojeh Kebab (Hähnchen), Kubideh (Hackfleisch) und Barg (Lammfilet).
              Serviert mit persischem Reis und gegrilltem Gemüse.
            </p>
          </div>

          <!-- Specialty 3 -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
            <h4 class="text-xl font-['Maven_Pro'] font-medium text-[#711521] mb-3">Ghormeh Sabzi</h4>
            <p class="font-['Maven_Pro'] text-sm">
              Der persische Klassiker - Schmortopf mit Kräutern, Bohnen und zartem Lammfleisch.
              Serviert mit Safranreis.
            </p>
          </div>

          <!-- Specialty 4 -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
            <h4 class="text-xl font-['Maven_Pro'] font-medium text-[#711521] mb-3">Vegetarische Gerichte</h4>
            <p class="font-['Maven_Pro'] text-sm">
              Kashk-e Bademjan (Auberginenpüree), Mirza Ghasemi (geräucherte Auberginen) und weitere
              vegetarische Köstlichkeiten.
            </p>
          </div>

          <!-- Specialty 5 -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
            <h4 class="text-xl font-['Maven_Pro'] font-medium text-[#711521] mb-3">Persische Vorspeisen</h4>
            <p class="font-['Maven_Pro'] text-sm">
              Kashk-e Bademjan, Mast-o Khiar (Joghurt mit Gurke), Salad Shirazi und frisches Fladenbrot.
            </p>
          </div>

          <!-- Specialty 6 -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
            <h4 class="text-xl font-['Maven_Pro'] font-medium text-[#711521] mb-3">Orientalische Desserts</h4>
            <p class="font-['Maven_Pro'] text-sm">
              Baklava, Safran-Eis, Faloodeh (persisches Sorbet) und weitere süße Verführungen.
            </p>
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="text-center bg-[#711521] text-white rounded-lg p-12">
        <h3 class="text-3xl font-['Maven_Pro'] font-medium mb-4">Reservieren Sie jetzt Ihren Tisch</h3>
        <p class="text-lg font-['Maven_Pro'] mb-8 max-w-2xl mx-auto">
          Erleben Sie persische Gastfreundschaft und kulinarische Exzellenz in unserem Restaurant.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a
            href="tel:+4917684512873"
            class="inline-block bg-white text-[#711521] hover:bg-gray-100 font-['Maven_Pro'] font-medium text-lg px-8 py-4 transition-colors"
          >
            ☎ +49 176 84512873
          </a>
          <a
            href="/kontakt"
            class="inline-block bg-[#ad083a] hover:bg-[#6B1C1C] text-white font-['Maven_Pro'] font-medium text-lg px-8 py-4 transition-colors"
          >
            ONLINE RESERVIEREN
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
