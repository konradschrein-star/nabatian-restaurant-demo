---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Gutschein | Nabatian">
  <Header />
  
  <main class="pt-24">
    <Hero 
      title="GUTSCHEIN" 
      subtitle="Persischer Genuss zum Verschenken – Ein Erlebnis für alle Sinne."
      backgroundImage="/assets/Authentisch_persisch_Fest.jpg"
    />

    <!-- Private Gifting Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-4xl font-serif text-neutral-900 mb-8 italic">Ein besonderes Geschenk</h2>
            <div class="prose prose-lg text-neutral-600 mb-10">
              <p>
                Suchen Sie nach einem Geschenk, das wirklich in Erinnerung bleibt? Mit einem NABATIAN Gutschein verschenken Sie nicht einfach nur ein Essen – sondern ein <strong>gesamtheitlich orientalisches Erlebnis</strong>.
              </p>
              <p>
                Ob für Geburtstage, Hochzeiten, Weihnachten oder einfach als kleines Dankeschön: Ein Gutschein für persische Kulinarik ist immer eine exzellente Wahl.
              </p>
              <ul class="space-y-4 list-none p-0 mt-8">
                <li class="flex items-center gap-3">
                  <span class="w-10 h-10 flex items-center justify-center bg-primary/10 text-primary rounded-full shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  </span>
                  <span class="text-neutral-800">Betrag frei wählbar</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="w-10 h-10 flex items-center justify-center bg-primary/10 text-primary rounded-full shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  </span>
                  <span class="text-neutral-800">Kein Verfallsdatum – Gültig solange es uns gibt</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="w-10 h-10 flex items-center justify-center bg-primary/10 text-primary rounded-full shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  </span>
                  <span class="text-neutral-800">Einlösbar im Restaurant, für Abholung & Catering</span>
                </li>
              </ul>
            </div>
            <a href="/kontakt" class="inline-block px-10 py-4 bg-primary text-white font-bold rounded-xl shadow-lg hover:shadow-xl transition-all">Gutschein anfragen</a>
          </div>

          <div class="relative grid grid-cols-2 gap-4">
            <div class="pt-12">
              <img src="https://nabatian.de/wp-content/uploads/2021/05/Gutschein-VS-1-768x1024.jpg" alt="Gutschein Vorderseite" class="rounded-2xl shadow-2xl transform -rotate-3 hover:rotate-0 transition-transform duration-500" />
            </div>
            <div>
              <img src="https://nabatian.de/wp-content/uploads/2021/05/Gutschein-RS-1-768x1024.jpg" alt="Gutschein Rückseite" class="rounded-2xl shadow-2xl transform rotate-3 hover:rotate-0 transition-transform duration-500" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Business Gifting Section -->
    <section class="py-24 bg-neutral-50 border-y border-neutral-100">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <h2 class="text-3xl md:text-4xl font-serif text-neutral-900 mb-8">Betriebliche Gutscheine</h2>
        <p class="text-lg text-neutral-600 mb-12 leading-relaxed">
          Ob Firmenjubiläum, Weihnachtsfeier oder als Anerkennung für Ihre Mitarbeiter – mit einem NABATIAN Gutschein schenken Sie Wertschätzung. Profitieren Sie von steuerlichen Vorteilen und attraktiven Staffelrabatten bei größeren Abnahmemengen.
        </p>
        <div class="inline-flex items-center gap-6 p-6 bg-white rounded-2xl shadow-sm border border-neutral-200">
          <div class="text-left">
            <p class="text-sm text-neutral-500 uppercase font-bold tracking-wider">Beratung & Bestellung</p>
            <p class="text-xl font-bold text-neutral-900">nasrin.nabatian@gmail.com</p>
          </div>
          <div class="h-12 w-[1px] bg-neutral-200 hidden sm:block"></div>
          <a href="mailto:nasrin.nabatian@gmail.com" class="text-primary font-bold hover:underline">Jetzt Kontakt aufnehmen</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
