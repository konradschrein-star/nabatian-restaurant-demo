---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

const title = "Galerie | Nabatian - Impressionen unserer persischen Küche";
const description = "Entdecken Sie die Vielfalt der persischen Küche bei Nabatian. Impressionen aus unserem Restaurant, Catering-Events und kulinarische Highlights.";
---

<Layout title={title} description={description}>
  <Header />

  <Hero
    title="GALERIE"
    subtitle="Impressionen unserer persischen Küche"
    backgroundImage="/images/hero-buffet.jpg"
  />

  <!-- Gallery Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Tabs (Future: Filter by category) -->
      <div class="text-center mb-12">
        <p class="text-lg font-['Maven_Pro'] max-w-2xl mx-auto">
          Erleben Sie die Vielfalt und Authentizität unserer persischen Küche in Bildern.
        </p>
      </div>

      <!-- Masonry Grid Gallery -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Image 1 - Buffet -->
        <div class="overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <img
            src="/images/hero-buffet.jpg"
            alt="Persisches Buffet - Nabatian Restaurant"
            class="w-full h-80 object-cover hover:scale-105 transition-transform duration-300"
          />
          <div class="p-4 bg-white">
            <h3 class="font-['Maven_Pro'] font-medium">Persisches Buffet</h3>
            <p class="font-['Maven_Pro'] text-sm text-gray-600">Authentische Vielfalt</p>
          </div>
        </div>

        <!-- Image 2 - Fest -->
        <div class="overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <img
            src="/images/Authentisch_persisch_Fest.jpg"
            alt="Persisches Fest - Catering Event"
            class="w-full h-80 object-cover hover:scale-105 transition-transform duration-300"
          />
          <div class="p-4 bg-white">
            <h3 class="font-['Maven_Pro'] font-medium">Catering Event</h3>
            <p class="font-['Maven_Pro'] text-sm text-gray-600">Persische Gastfreundschaft</p>
          </div>
        </div>

        <!-- Image 3 - Gutschein -->
        <div class="overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <img
            src="/images/Gutschein-VS-1-768x1024.jpg"
            alt="Nabatian Gutschein"
            class="w-full h-80 object-cover hover:scale-105 transition-transform duration-300"
          />
          <div class="p-4 bg-white">
            <h3 class="font-['Maven_Pro'] font-medium">Geschenkgutscheine</h3>
            <p class="font-['Maven_Pro'] text-sm text-gray-600">Perfektes Geschenk</p>
          </div>
        </div>

        <!-- Image 4 - Gutschein Rückseite -->
        <div class="overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <img
            src="/images/Gutschein-RS-1-768x1024.jpg"
            alt="Nabatian Gutschein Rückseite"
            class="w-full h-80 object-cover hover:scale-105 transition-transform duration-300"
          />
          <div class="p-4 bg-white">
            <h3 class="font-['Maven_Pro'] font-medium">Gutschein Details</h3>
            <p class="font-['Maven_Pro'] text-sm text-gray-600">Einlösbar im Restaurant</p>
          </div>
        </div>

        <!-- Image 5 - Logo -->
        <div class="overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <img
            src="/images/cropped-Nabatian_Logo.png"
            alt="Nabatian Restaurant Logo"
            class="w-full h-80 object-contain bg-white p-8 hover:scale-105 transition-transform duration-300"
          />
          <div class="p-4 bg-white">
            <h3 class="font-['Maven_Pro'] font-medium">Nabatian Marke</h3>
            <p class="font-['Maven_Pro'] text-sm text-gray-600">Authentisch Persisch</p>
          </div>
        </div>
      </div>

      <!-- Placeholder for Future CMS Integration -->
      <div class="text-center mt-16">
        <p class="font-['Maven_Pro'] text-gray-600 italic">
          Weitere Bilder folgen in Kürze über unser CMS-System.
        </p>
        <p class="font-['Maven_Pro'] text-sm text-gray-500 mt-2">
          Folgen Sie uns auf Instagram für aktuelle Impressionen:
          <a href="https://www.instagram.com/nabatian_restaurant_catering" target="_blank" class="text-[#711521] hover:text-[#ad083a]">
            @nabatian_restaurant_catering
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-['Maven_Pro'] font-medium mb-4">Erleben Sie es selbst!</h2>
      <p class="text-lg font-['Maven_Pro'] mb-8">
        Besuchen Sie uns im Restaurant oder buchen Sie unser Catering für Ihr Event.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/restaurant"
          class="inline-block bg-[#711521] hover:bg-[#6B1C1C] text-white font-['Maven_Pro'] font-medium text-lg px-8 py-4 transition-colors"
        >
          RESTAURANT BESUCHEN
        </a>
        <a
          href="/catering"
          class="inline-block bg-[#ad083a] hover:bg-[#6B1C1C] text-white font-['Maven_Pro'] font-medium text-lg px-8 py-4 transition-colors"
        >
          CATERING BUCHEN
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
