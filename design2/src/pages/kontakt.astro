---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm';

const title = "Kontakt | Nabatian - Persisches Restaurant & Catering Heilbronn";
const description = "Kontaktieren Sie Nabatian Restaurant & Catering in Heilbronn. Reservierungen, Catering-Anfragen und Informationen.";
---

<Layout title={title} description={description}>
  <Header />

  <Hero
    title="KONTAKT"
    subtitle="Wir freuen uns auf Ihre Nachricht"
    backgroundImage="/images/hero-buffet.jpg"
  />

  <!-- Contact Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-['Maven_Pro'] font-medium mb-8">Nabatian Restaurant & Catering</h2>

          <div class="space-y-6 font-['Maven_Pro']">
            <!-- Address -->
            <div>
              <h3 class="font-medium text-[#711521] text-lg mb-2">📍 Adresse:</h3>
              <p>
                Im Haselter 9/1<br />
                74080 Heilbronn<br />
                Am Sonnenbrunnen in Böckingen
              </p>
            </div>

            <!-- Phone -->
            <div>
              <h3 class="font-medium text-[#711521] text-lg mb-2">☎ Telefon:</h3>
              <p>
                <a href="tel:+4917684512873" class="hover:text-[#ad083a] text-lg">
                  +49 176 84512873
                </a>
              </p>
            </div>

            <!-- Email -->
            <div>
              <h3 class="font-medium text-[#711521] text-lg mb-2">📧 E-Mail:</h3>
              <p>
                <a href="mailto:nasrin.nabatian@gmail.com" class="hover:text-[#ad083a]">
                  nasrin.nabatian@gmail.com
                </a>
              </p>
            </div>

            <!-- Opening Hours -->
            <div>
              <h3 class="font-medium text-[#711521] text-lg mb-3">🕐 Öffnungszeiten:</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span>Montag & Dienstag:</span>
                  <span class="text-gray-500">Ruhetag</span>
                </div>
                <div class="flex justify-between">
                  <span>Mittwoch & Donnerstag:</span>
                  <span class="text-[#711521] font-medium">17:00 - 22:00 Uhr</span>
                </div>
                <div class="flex justify-between">
                  <span>Freitag & Samstag:</span>
                  <span class="text-[#711521] font-medium">17:00 - 23:00 Uhr</span>
                </div>
                <div class="flex justify-between">
                  <span>Sonntag Frühstück:</span>
                  <span class="text-[#711521] font-medium">09:00 - 12:00 Uhr</span>
                </div>
                <div class="flex justify-between">
                  <span>Sonntag Mittagessen:</span>
                  <span class="text-[#711521] font-medium">12:00 - 14:00 Uhr</span>
                </div>
              </div>
            </div>

            <!-- Social Media -->
            <div>
              <h3 class="font-medium text-[#711521] text-lg mb-3">🌐 Social Media:</h3>
              <div class="flex flex-col space-y-2">
                <a
                  href="https://www.instagram.com/nabatian_restaurant_catering"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-black hover:text-[#711521] transition-colors flex items-center"
                >
                  <span class="mr-2">📷</span> Instagram
                </a>
                <a
                  href="https://www.facebook.com/profile.php?id=100045701568663"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-black hover:text-[#711521] transition-colors flex items-center"
                >
                  <span class="mr-2">👥</span> Facebook
                </a>
                <a
                  href="https://de.linkedin.com/company/nabatian-cantina-catering"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-black hover:text-[#711521] transition-colors flex items-center"
                >
                  <span class="mr-2">💼</span> LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Maps Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-['Maven_Pro'] font-medium text-center mb-8">Anfahrt</h2>
      <div class="rounded-lg shadow-lg overflow-hidden">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2617.5!2d9.2!3d49.15!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDnCsDA5JzAwLjAiTiA5wrAxMicwMC4wIkU!5e0!3m2!1sde!2sde!4v1234567890"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p class="text-center font-['Maven_Pro'] text-sm mt-4 text-gray-600">
        Im Haselter 9/1, 74080 Heilbronn - Am Sonnenbrunnen in Böckingen
      </p>
    </div>
  </section>

  <Footer />
</Layout>
