---
---

<section class="py-24 bg-neutral-950 overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      
      <!-- Text Side -->
      <div class="order-2 lg:order-1">
        <div class="inline-block px-4 py-1 border border-primary/30 rounded-full mb-6">
          <span class="text-primary text-xs font-bold tracking-widest uppercase italic">Genuss verschenken</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-serif text-white mb-8 leading-tight">
          Verschenken Sie <span class="text-primary italic">echten Genuss</span> & persische Gastfreundschaft
        </h2>
        
        <div class="space-y-6 text-neutral-400 text-lg leading-relaxed mb-10">
          <p>
            Mit unserem NABATIAN Gutschein verschenken Sie mehr als nur ein Essen. Sie verschenken ein persisches Esserlebnis in einer Atmosphäre wie aus 1001 Nacht.
          </p>
          <p>
            Ob Geburtstag, Jubiläum oder als Dankeschön für Mitarbeiter – ein Gutschein ist die perfekte Aufmerksamkeit für jeden Anlass. Gerne verschicken wir den Gutschein auch direkt an Ihre Lieblingsmenschen.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-8">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-white font-bold text-sm">Bestell-Hotline</p>
              <a href="tel:01761234567" class="text-primary hover:text-white transition-colors">0176 1234567</a>
            </div>
          </div>
          
          <a 
            href={`${import.meta.env.BASE_URL}kontakt`} 
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-black font-bold rounded-lg hover:bg-primary transition-colors h-fit"
          >
            Jetzt anfragen
          </a>
        </div>
      </div>

      <!-- Image Side (Mockup style) -->
      <div class="order-1 lg:order-2 relative">
        <div class="relative z-10 w-full aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl border border-white/10 group">
          <img 
            src={`${import.meta.env.BASE_URL}assets/Gutschein-VS-1-768x1024.jpg`} 
            alt="Nabatian Gutschein Vorderseite" 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-8">
            <p class="text-white font-serif text-xl">Vorderseite: Stilvoll & Edel</p>
          </div>
        </div>
        
        <!-- Decorative backend card overlap -->
        <div class="absolute -bottom-10 -left-10 z-20 w-3/4 aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl border border-white/10 hidden md:block group/back">
          <img 
            src={`${import.meta.env.BASE_URL}assets/Gutschein-RS-1-768x1024.jpg`} 
            alt="Nabatian Gutschein Rückseite" 
            class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-700"
          />
        </div>
        
        <!-- Decorative golden element -->
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/20 rounded-full blur-3xl -z-10 animate-pulse"></div>
      </div>

    </div>
  </div>
</section>
