---
const images = [
  { src: '/assets/Authentisch_persisch_Fest.jpg', alt: 'Persisches Festmahl' },
  { src: '/assets/Authentisch_persisch_Fest.jpg', alt: 'Restaurant Ambiente' },
  { src: '/assets/Authentisch_persisch_Fest.jpg', alt: 'Traditionelle Gewürze' },
  { src: '/assets/Authentisch_persisch_Fest.jpg', alt: 'Persische Spezialitäten' },
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-serif text-neutral-900 mb-4">Eindrücke aus unserer <span class="text-primary italic">orientalischen Küche</span></h2>
      <p class="text-neutral-500">
        Erleben Sie die Farben, Düfte und den Geschmack Persiens in jedem Detail unserer Gerichte.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {images.map((image, index) => (
        <div class={`relative overflow-hidden group rounded-xl aspect-[3/4] ${index % 2 === 1 ? 'md:translate-y-8' : ''}`}>
          <img 
            src={image.src} 
            alt={image.alt} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center p-4 text-center">
            <span class="text-white text-sm font-medium tracking-wider uppercase">{image.alt}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
