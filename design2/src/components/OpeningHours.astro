---
interface Props {
  variant?: 'light' | 'dark' | 'premium';
  className?: string;
}

const { variant = 'premium', className = '' } = Astro.props;

const hours = [
  { label: 'Abendessen', days: 'Mittwoch - Donnerstag', time: '17:00 - 22:00' },
  { label: 'Abendessen', days: 'Freitag - Samstag', time: '17:00 - 23:00' },
  { label: 'Abendessen', days: 'Sonntag', time: '17:00 - 22:00' },
  { label: 'Mittagessen', days: 'Sonntag', time: '12:00 - 14:00' },
  { label: 'Frühstück', days: 'Sonntag', time: '09:00 - 12:00' },
];

const containerClasses = variant === 'premium' 
  ? 'bg-neutral-900 text-white p-10 rounded-[2.5rem] shadow-2xl border border-white/5 relative overflow-hidden'
  : variant === 'dark'
    ? 'bg-neutral-900/40 backdrop-blur-sm p-6 rounded-2xl border border-white/5'
    : 'bg-white p-8 rounded-[2rem] shadow-xl border border-neutral-100';

const textTitleClasses = variant === 'light' ? 'text-neutral-900' : 'text-white';
const textItemClasses = variant === 'light' ? 'text-neutral-600' : 'text-neutral-400';
const borderClasses = variant === 'light' ? 'border-neutral-100' : 'border-white/5';
---

<div class={`${containerClasses} ${className}`}>
  {variant === 'premium' && (
    <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-bl-full -mr-16 -mt-16 pointer-events-none"></div>
  )}

  <h3 class={`text-2xl font-serif mb-8 flex items-center gap-3 ${textTitleClasses}`}>
    <span class="text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </span>
    Öffnungszeiten
  </h3>
  
  <div class="space-y-6">
    {hours.map((item) => (
      <div class={`group relative pb-4 border-b last:border-0 ${borderClasses}`}>
        <p class="text-[10px] uppercase tracking-[0.2em] text-primary font-bold mb-1 opacity-80 group-hover:opacity-100 transition-opacity">
          {item.label}
        </p>
        <div class="flex justify-between items-end">
          <span class={`font-serif text-lg ${variant === 'light' ? 'text-neutral-800' : 'text-neutral-200'}`}>
            {item.days}
          </span>
          <span class="text-primary font-bold tabular-nums">
            {item.time}
          </span>
        </div>
      </div>
    ))}
  </div>
  
  <div class="mt-10 flex flex-col gap-4">
    <p class={`text-xs italic leading-relaxed ${textItemClasses} max-w-[240px]`}>
      * An Feiertagen können unsere Öffnungszeiten abweichen.
    </p>
    
    <a 
      href={`${import.meta.env.BASE_URL}kontakt`} 
      class={`inline-flex items-center gap-2 text-sm font-bold tracking-tight transition-all
        ${variant === 'light' 
          ? 'text-neutral-900 hover:text-primary' 
          : 'text-white hover:text-primary underline decoration-primary/30 underline-offset-8'}`}
    >
      Tisch reservieren
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</div>
