---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
}

const { 
  title = "NABATIAN RESTAURANT", 
  subtitle = "Persische Köstlichkeiten im Herzen von Heilbronn",
  backgroundImage = `${import.meta.env.BASE_URL}assets/Authentisch_persisch_Fest.jpg`
} = Astro.props;
---

<section class="relative min-height-[80vh] flex items-center justify-center overflow-hidden py-32 px-4 group">
  <!-- Background Image with Parallax Effect (CSS only) -->
  <div class="absolute inset-0 z-0">
    <div 
      class="absolute inset-0 bg-cover bg-center scale-110 transition-transform duration-10000 ease-out group-hover:scale-100"
      style={`background-image: url('${backgroundImage}')`}
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/40 to-black/80"></div>
  </div>

  <div class="relative z-10 container mx-auto text-center max-w-4xl">
    <div class="mb-6 inline-block">
      <span class="block w-16 h-1 bg-primary mx-auto mb-4 animate-width-grow"></span>
      <p class="text-primary tracking-[0.3em] uppercase text-sm font-bold mb-2 opacity-0 animate-fade-in-up" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
        Willkommen bei Nabatian
      </p>
    </div>
    
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-serif text-white mb-8 tracking-tighter opacity-0 animate-fade-in-up" style="animation-delay: 0.4s; animation-fill-mode: forwards;">
      {title}
    </h1>
    
    <p class="text-xl md:text-2xl text-neutral-300 mb-12 font-light max-w-2xl mx-auto leading-relaxed opacity-0 animate-fade-in-up" style="animation-delay: 0.6s; animation-fill-mode: forwards;">
      {subtitle}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 opacity-0 animate-fade-in-up" style="animation-delay: 0.8s; animation-fill-mode: forwards;">
      <a 
        href={`${import.meta.env.BASE_URL}speisekarte`} 
        class="group relative px-10 py-5 bg-primary text-black font-bold rounded-lg overflow-hidden transition-all hover:shadow-[0_0_30px_rgba(255,215,0,0.4)]"
      >
        <span class="relative z-10 flex items-center gap-2">
          Speisekarte entdecken
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </a>
      
      <a 
        href={`${import.meta.env.BASE_URL}kontakt`} 
        class="px-10 py-5 border border-white/30 text-white font-bold rounded-lg hover:bg-white hover:text-black transition-all backdrop-blur-sm"
      >
        Tisch reservieren
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-60">
    <span class="text-[10px] uppercase tracking-[0.2em] text-white font-semibold">Scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-primary to-transparent"></div>
  </div>
</section>

<style>
  @keyframes width-grow {
    from { width: 0; }
    to { width: 4rem; }
  }
  
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-width-grow {
    animation: width-grow 1s ease-out forwards;
  }

  .animate-fade-in-up {
    animation: fade-in-up 1s ease-out forwards;
  }

  /* Slow Ken Burns style background */
  @keyframes kenburns {
    0% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }
  
  .duration-10000 {
    animation-duration: 20s;
  }
</style>
