---
// Hero Component - Professional Hero Section with Full-Screen Image

interface Props {
  title: string;
  subtitle: string;
  backgroundImage: string;
  ctaText?: string;
  ctaLink?: string;
  overlayOpacity?: number; // 0-100, default 60
}

const {
  title,
  subtitle,
  backgroundImage,
  ctaText,
  ctaLink,
  overlayOpacity = 60,
} = Astro.props;

const overlayClass = overlayOpacity === 60 ? 'bg-black/60' : `bg-black/${overlayOpacity}`;
---

<section class="relative h-[70vh] min-h-[500px] max-h-[800px] flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <img
    src={backgroundImage}
    alt=""
    class="absolute inset-0 w-full h-full object-cover object-center"
    loading="eager"
    decoding="async"
  />

  <!-- Dark Overlay with Gradient -->
  <div class={`absolute inset-0 ${overlayClass}`}></div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/50"></div>

  <!-- Hero Content -->
  <div class="relative z-10 text-center text-white px-4 max-w-5xl mx-auto">
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-['Quattrocento_Sans'] font-medium tracking-wide mb-4 md:mb-6 drop-shadow-2xl">
      {title}
    </h1>
    <p class="text-lg sm:text-xl md:text-2xl font-['Maven_Pro'] mb-6 md:mb-10 max-w-3xl mx-auto leading-relaxed drop-shadow-lg opacity-95">
      {subtitle}
    </p>
    {ctaText && ctaLink && (
      <a
        href={ctaLink}
        class="inline-block bg-[#711521] hover:bg-[#8a1a2a] text-white font-['Maven_Pro'] font-semibold text-base md:text-lg px-8 md:px-12 py-3 md:py-4 rounded-sm transition-all duration-300 shadow-xl hover:shadow-2xl hover:scale-105 transform"
      >
        {ctaText}
      </a>
    )}
  </div>
</section>
